# Weather Underground
wu:
  api_key: "YOUR_API_KEY"
  units: "m"  # m = metric (°C, km/h, mm, hPa)

  # Primary station (main station, supports gap-fill from secondary stations)
  primary_station:
    id: "ISANVI15"
    name: "San Vito al Tagliamento"

  # Secondary stations (optional)
  secondary_stations:
    - id: "IPORDENONE42"
      name: "Pordenone Centro"
      use_for_gap_fill: true    # contributes data to fill gaps in primary station
    - id: "IUDINE10"
      name: "Udine Nord"
      use_for_gap_fill: false

# Database (PostgreSQL)
database:
  host: "localhost"
  port: 5432
  name: "weathercloud"
  user: "weather"
  password: "weather"
  schema: "weather"

# API Base URLs
api:
  current_conditions: "https://api.weather.com/v2/pws/observations/current"
  daily_summary_7day: "https://api.weather.com/v2/pws/dailysummary/7day"
  rapid_history_1day: "https://api.weather.com/v2/pws/observations/all/1day"
  hourly_history_7day: "https://api.weather.com/v2/pws/observations/hourly/7day"
  historical: "https://api.weather.com/v2/pws/history/daily"
  forecast_5day: "https://api.weather.com/v3/wx/forecast/daily/5day"

# Job Scheduler
scheduler:
  rapid_history:
    enabled: true
    interval_hours: 4
  hourly_history:
    enabled: true
    interval_hours: 12

  # Autonomous historical recovery (daily, all stations)
  auto_recovery:
    enabled: true
    daily_api_budget: 1000  # max API calls per day across all stations
    run_at: "03:00"         # time of day to run (HH:MM, 24h)

# App
app:
  host: "0.0.0.0"
  port: 5001
  debug: false
  homepage_auto_refresh: true    # auto-refresh homepage when open in browser
  homepage_refresh_minutes: 2    # refresh interval in minutes
